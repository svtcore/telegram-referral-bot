# Telegram Referral Bot Configuration
# Copy this file to .env and fill in your values

# Bot name without @ symbol (example_random_bot)
BOT_NAME=

# Number of accounts to process
COUNT=

# Your referral ID (from t.me/bot?start=12345, use only 12345)
REFER_ID=

# Channel username to join before starting the bot (optional, without @)
CHANNEL_NAME=

# Delay range in seconds between each account operation
DELAY_MIN=10
DELAY_MAX=15
